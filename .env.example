# Copy to .env in this directory and edit. Used by bootstrap, redeploy, and challenge registration.

# Required — hostname or IP participants type in the browser to open spawned apps (no http://).
# Example (EC2): ec2-203-0-113-50.compute-1.amazonaws.com
# Example (local testing on one machine): 127.0.0.1
DOCKER_CHALLENGES_PUBLIC_HOST=

# Optional alias if you prefer this name (scripts copy it to DOCKER_CHALLENGES_PUBLIC_HOST).
# PWNZZAI_PUBLIC_HOST=

# docker_challenges plugin — cloned when building the CTFd image (defaults = northdpole fork with fixes).
# DOCKER_CHALLENGES_GIT_URL=https://github.com/northdpole/CTFd-Docker-Challenges.git
# DOCKER_CHALLENGES_REF=master
# Optional: cache-buster for plugin clone step (redeploy script auto-sets this each run).
# DOCKER_CHALLENGES_CACHE_BUSTER=

# Recommended for production CTFd
# CTFD_SECRET_KEY=

# Compose: start the local shared Ollama container (GPU). Leave empty to run CTFd only and use a remote model host.
# COMPOSE_PROFILES=local-ollama
#
# Bind address for published Ollama port (default all interfaces). Tighten in production.
# OLLAMA_PUBLISH=0.0.0.0:11434

# Shared model/provider contract for spawned challenge containers.
# `MODEL_PROVIDER=auto` prefers OpenAI when a key is available, then falls back to Ollama.
# MODEL_PROVIDER=auto
# OLLAMA_HOST=http://172.17.0.1:11434
# OLLAMA_MODEL=mistral:7b
# OLLAMA_FALLBACK_MODEL=llama3.2:1b
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# LiteLLM route when set (e.g. gemini/gemini-2.0-flash). Unset = openai/{OPENAI_MODEL}.
# LITELLM_MODEL=
#
# Per-lab cloud model names (Flask app / workshop). Bare names get openai/ prefix; use provider/model for Claude, Gemini, etc.
# Defaults: LAB_CLOUD_LLM_MODEL=gpt-3.5-turbo, LAB_CLOUD_LLM_MODEL_EXCESSIVE_AGENCY=gpt-4o-mini
# LAB_CLOUD_LLM_MODEL=
# LAB_CLOUD_LLM_MODEL_EXCESSIVE_AGENCY=
# See docs/workshop-cloud-llm-setup.md for step-by-step examples.
# Optional UI overrides when using a non-OpenAI backend:
# LLM_UI_PROVIDER_NAME=
# LLM_UI_KEY_LABEL=
# LLM_UI_KEY_PLACEHOLDER=
# LLM_UI_DOCS_URL=
# LLM_UI_DOCS_ANCHOR=
# LLM_UI_LAB_HEADING=
# LLM_UI_LAB_DESCRIPTION=
# ALLOW_PRECONFIGURED_OPENAI_KEY=true
# PREFER_SESSION_OPENAI_KEY=true
# MODEL_TIMEOUT_SECONDS=60
# ENABLE_PROVIDER_FALLBACK=true
