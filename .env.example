# Copy to .env in this directory and edit. Used by bootstrap, redeploy, and challenge registration.

# Required — hostname or IP participants type in the browser to open spawned apps (no http://).
# Example (EC2): ec2-203-0-113-50.compute-1.amazonaws.com
# Example (local testing on one machine): 127.0.0.1
DOCKER_CHALLENGES_PUBLIC_HOST=

# Optional alias if you prefer this name (scripts copy it to DOCKER_CHALLENGES_PUBLIC_HOST).
# PWNZZAI_PUBLIC_HOST=

# docker_challenges plugin — cloned when building the CTFd image (defaults = northdpole fork with fixes).
# DOCKER_CHALLENGES_GIT_URL=https://github.com/northdpole/CTFd-Docker-Challenges.git
# DOCKER_CHALLENGES_REF=master

# Recommended for production CTFd
# CTFD_SECRET_KEY=
